# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_ID=claude-sonnet-4-6
MAX_TOKENS=4096

# ── Embeddings & Vector Store ──────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=data/vector_store
COLLECTION_NAME=financial_reports
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Gmail: create an App Password at myaccount.google.com/security
# Outlook: smtp.office365.com port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Favorite Stock Tickers ─────────────────────────────────────────────────────
TRACKED_TICKERS=AAPL,MSFT,NVDA

# ── News API (optional) ────────────────────────────────────────────────────────
# Free key at newsapi.org
NEWS_API_KEY=

# ── Coach Mode ─────────────────────────────────────────────────────────────────
# on  → plain English, beginner-friendly, every term explained
# off → advanced mode (default)
COACH_MODE=off

# ── Alpaca Paper Trading ───────────────────────────────────────────────────────
# Sign up free at alpaca.markets → switch to Paper Trading → generate API keys
# No real money — everything is simulated
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
